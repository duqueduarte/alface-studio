def resource_path(relative_path):
    try:
        base_path = Path(sys._MEIPASS)
    except Exception:
        base_path = Path(__file__).parent
    return Path(base_path) / relative_path


def get_ffmpeg():
    ffmpeg_system = shutil.which("ffmpeg")
    if ffmpeg_system:
        return ffmpeg_system
    raise FileNotFoundError("ffmpeg.exe não encontrado no PATH.")


class CountdownWindow(QWidget):
    finished = pyqtSignal()

    def __init__(self, seconds=3):
        super().__init__()
        self.seconds = seconds
        self.setWindowFlags(Qt.FramelessWindowHint | Qt.WindowStaysOnTopHint | Qt.Tool)
        self.setAttribute(Qt.WA_TranslucentBackground)
        self.setStyleSheet("background-color: rgba(0,0,0,160);")
        self.label = QLabel(str(self.seconds), self)
        self.label.setAlignment(Qt.AlignCenter)
        self.label.setStyleSheet("color: red; font-size: 96px; font-weight: bold;")
        layout = QVBoxLayout()
        layout.addStretch()
        layout.addWidget(self.label)
        layout.addStretch()
        self.setLayout(layout)
        self.resize(300, 300)
        screen = QApplication.desktop().screenGeometry()
        self.move(screen.center() - self.rect().center())
        self.timer = QTimer()
        self.timer.timeout.connect(self.update_countdown)

    def start(self):
        self.show()
        self.timer.start(1000)

    def update_countdown(self):
        self.seconds -= 1
        if self.seconds <= 0:
            self.timer.stop()
            self.close()
            self.finished.emit()
        else:
            self.label.setText(str(self.seconds))


class RegionSelector(QWidget):
    region_selected = pyqtSignal(dict)

    def __init__(self, monitor):
        super().__init__()
        self.monitor = monitor
        self.setWindowFlags(Qt.WindowStaysOnTopHint | Qt.FramelessWindowHint | Qt.Tool)
        self.setAttribute(Qt.WA_TranslucentBackground)
        self.setCursor(Qt.CrossCursor)
        self.setFocusPolicy(Qt.StrongFocus)
        self.setMouseTracking(True)
        self.setWindowModality(Qt.ApplicationModal)
        self.start_pos = None
        self.end_pos = None
        self.setGeometry(self.monitor["left"], self.monitor["top"], self.monitor["width"], self.monitor["height"])
        self.showFullScreen()
        self.raise_()
        self.activateWindow()

    def paintEvent(self, event):
        painter = QPainter(self)
        painter.fillRect(self.rect(), QColor(0, 0, 0, 80))
        if self.start_pos and self.end_pos:
            rect = QRect(self.start_pos, self.end_pos)
            pen = QPen(QColor(0, 180, 255, 220), 2)
            painter.setPen(pen)
            painter.drawRect(rect.normalized())

    def mousePressEvent(self, event):
        if event.button() == Qt.LeftButton:
            self.start_pos = event.pos()
            self.end_pos = event.pos()
            self.update()

    def mouseMoveEvent(self, event):
        if self.start_pos:
            self.end_pos = event.pos()
            self.update()

    def mouseReleaseEvent(self, event):
        if event.button() == Qt.LeftButton and self.start_pos:
            rect = QRect(self.start_pos, self.end_pos).normalized()
            region = {
                "left": self.monitor["left"] + rect.left(),
                "top": self.monitor["top"] + rect.top(),
                "width": rect.width(),
                "height": rect.height(),
            }
            if region["width"] < 10 or region["height"] < 10:
                self.close()
                return
            self.region_selected.emit(region)
            self.close()


class RecordingOverlay(QWidget):
    def __init__(self, region):
        super().__init__()
        self.region = region
        self.setWindowFlags(Qt.FramelessWindowHint | Qt.WindowStaysOnTopHint | Qt.Tool)
        self.setAttribute(Qt.WA_TranslucentBackground)
        self.setAttribute(Qt.WA_TransparentForMouseEvents)
        self.setGeometry(region["left"], region["top"], region["width"], region["height"])
        try:
            hwnd = int(self.winId())
            ctypes.windll.user32.SetWindowDisplayAffinity(hwnd, 0x00000011)  # WDA_EXCLUDEFROMCAPTURE
        except Exception:
            pass
        self.paused = False
        self.intensity = 255
        self.direction = -30
        self.timer = QTimer()
        self.timer.timeout.connect(self._tick)
        self.timer.start(300)
        self.show()

    def _tick(self):
        if not self.paused:
            self.intensity += self.direction
            if self.intensity <= 100 or self.intensity >= 255:
                self.direction *= -1
        self.update()

    def set_paused(self, paused: bool):
        self.paused = paused
        self.update()

    def paintEvent(self, event):
        painter = QPainter(self)
        pen = QPen(QColor(180, 180, 180), 3) if self.paused else QPen(QColor(self.intensity, 0, 0), 3)
        painter.setPen(pen)
        painter.drawRect(self.rect().adjusted(1, 1, -2, -2))


def _compute_webcam_rect(region, w, h, position):
    if position == "Superior Esquerda":
        x = region["left"] + 20
        y = region["top"] + 20
    elif position == "Superior Direita":
        x = region["left"] + region["width"] - w - 20
        y = region["top"] + 20
    elif position == "Inferior Esquerda":
        x = region["left"] + 20
        y = region["top"] + region["height"] - h - 20
    elif position == "Inferior Direita":
        x = region["left"] + region["width"] - w - 20
        y = region["top"] + region["height"] - h - 20
    else:
        x = region["left"] + 20
        y = region["top"] + 20
    return x, y, w, h


def _overlay_frame(base_bgr, overlay_bgr, x, y):
    h, w = overlay_bgr.shape[:2]
    H, W = base_bgr.shape[:2]
    x0, y0 = max(0, x), max(0, y)
    x1, y1 = min(W, x0 + w), min(H, y0 + h)
    ox0, oy0 = 0, 0
    ox1, oy1 = x1 - x0, y1 - y0
    if x0 >= W or y0 >= H or ox1 <= 0 or oy1 <= 0:
        return
    base_bgr[y0:y1, x0:x1] = overlay_bgr[oy0:oy1, ox0:ox1]


class CaptureThread(threading.Thread):
    def __init__(self, region, fps, state, frame_queue,
                 webcam_cap=None, webcam_pos="Superior Direita", webcam_size=(240, 180)):
        super().__init__(daemon=True)
        self.region = region
        self.fps = fps
        self.state = state
        self.frame_interval = 1.0 / fps
        self.frame_queue = frame_queue

        self.webcam_cap = webcam_cap
        self.webcam_pos = webcam_pos
        self.webcam_size = webcam_size
        self._last_webcam_frame = None

        x, y, w, h = _compute_webcam_rect(region, webcam_size[0], webcam_size[1], webcam_pos)
        self.webcam_draw_x = x - region["left"]
        self.webcam_draw_y = y - region["top"]

    def _grab_screen(self, sct):
        frame = np.array(sct.grab(self.region))[:, :, :3]  # BGRA -> BGR
        return np.ascontiguousarray(frame)

    def _grab_webcam(self):
        if self.webcam_cap is None or not self.webcam_cap.isOpened():
            return self._last_webcam_frame
        ret, frame = self.webcam_cap.read()
        if not ret or frame is None:
            return self._last_webcam_frame
        try:
            resized = cv2.resize(frame, self.webcam_size, interpolation=cv2.INTER_AREA)
        except Exception:
            resized = frame
        self._last_webcam_frame = resized
        return resized

    def _draw_cursor(self, frame):
        try:
            x, y = pyautogui.position()
            rel_x = x - self.region["left"]
            rel_y = y - self.region["top"]
            if 0 <= rel_x < frame.shape[1] and 0 <= rel_y < frame.shape[0]:
                pts = np.array([
                    [rel_x, rel_y],
                    [rel_x, rel_y + 25],
                    [rel_x + 5, rel_y + 20],
                    [rel_x + 10, rel_y + 30],
                    [rel_x + 14, rel_y + 28],
                    [rel_x + 8, rel_y + 18],
                    [rel_x + 18, rel_y + 18]
                ], dtype=np.int32).reshape((-1, 1, 2))
                cv2.fillPoly(frame, [pts], (255, 255, 255))
                cv2.polylines(frame, [pts], True, (0, 0, 0), 2)
        except Exception:
            pass

    def run(self):
        try:
            sct = mss()
            next_frame_time = time.perf_counter()
            while self.state["recording"]:
                if self.state["paused"]:
                    time.sleep(0.05)
                    next_frame_time = time.perf_counter()
                    continue

                now = time.perf_counter()
                if now < next_frame_time:
                    time.sleep(max(0, next_frame_time - now))

                frame = self._grab_screen(sct)

                if self.state.get("cursor", False):
                    self._draw_cursor(frame)

                if self.webcam_cap is not None:
                    wcam = self._grab_webcam()
                    if wcam is not None:
                        try:
                            _overlay_frame(frame, wcam, self.webcam_draw_x, self.webcam_draw_y)
                            x0, y0 = self.webcam_draw_x, self.webcam_draw_y
                            x1, y1 = x0 + wcam.shape[1], y0 + wcam.shape[0]
                            cv2.rectangle(frame, (x0, y0), (x1, y1), (204, 0, 0), 2)
                        except Exception:
                            pass

                timestamp = time.perf_counter()
                try:
                    self.frame_queue.put_nowait((frame, timestamp))
                except queue.Full:
                    pass

                next_frame_time += self.frame_interval
                if time.perf_counter() - next_frame_time > self.frame_interval:
                    next_frame_time = time.perf_counter()
        except Exception as e:
            print(f"Erro na captura de tela: {e}")


class WriterThread(threading.Thread):
    def __init__(self, writer, frame_queue, state, start_time, fps):
        super().__init__(daemon=True)
        self.writer = writer
        self.frame_queue = frame_queue
        self.state = state
        self.start_time = start_time
        self.fps = fps
        self.written_frames = 0
        self.last_frame = None

    def run(self):
        try:
            while self.state["recording"] or not self.frame_queue.empty():
                try:
                    frame, ts = self.frame_queue.get(timeout=0.05)
                    self.last_frame = frame
                except queue.Empty:
                    pass

                if self.last_frame is None:
                    time.sleep(0.01)
                    continue

                if self.state["paused"]:
                    time.sleep(0.05)
                    continue

                now = time.perf_counter()
                elapsed = now - self.start_time
                target_frames = int(elapsed * self.fps)

                while self.written_frames < target_frames:
                    self.writer.write(self.last_frame)
                    self.written_frames += 1
        except Exception as e:
            print(f"Erro na escrita de vídeo: {e}")


class WebcamOverlay(QWidget):
    # Preview opcional (não influencia a gravação)
    def __init__(self, region, cam_index=0, position="Superior Direita", initial_size=(240, 180)):
        super().__init__()
        self.region = region
        self.cam_index = cam_index
        w, h = initial_size

        if position == "Superior Esquerda":
            x = region["left"] + 20
            y = region["top"] + 20
        elif position == "Superior Direita":
            x = region["left"] + region["width"] - w - 20
            y = region["top"] + 20
        elif position == "Inferior Esquerda":
            x = region["left"] + 20
            y = region["top"] + region["height"] - h - 20
        elif position == "Inferior Direita":
            x = region["left"] + region["width"] - w - 20
            y = region["top"] + region["height"] - h - 20
        else:
            x = region["left"] + 20
            y = region["top"] + 20

        self.setWindowFlags(Qt.FramelessWindowHint | Qt.WindowStaysOnTopHint | Qt.Tool)
        self.setAttribute(Qt.WA_TranslucentBackground)
        self.setGeometry(x, y, w, h)

        self.cap = cv2.VideoCapture(cam_index, cv2.CAP_DSHOW)
        if not self.cap.isOpened():
            raise RuntimeError(f"Não foi possível abrir a webcam no índice {cam_index}")
        self.cap.set(cv2.CAP_PROP_FRAME_WIDTH, 640)
        self.cap.set(cv2.CAP_PROP_FRAME_HEIGHT, 480)

        self.label = QLabel(self)
        self.label.setStyleSheet("background-color: rgba(0,0,0,160); border: 2px solid #cc0000;")
        self.label.setGeometry(0, 0, self.width(), self.height())

        self.timer = QTimer()
        self.timer.timeout.connect(self.update_frame)
        self.timer.start(33)

        self.show()

    def update_frame(self):
        if not self.cap.isOpened():
            return
        ret, frame = self.cap.read()
        if not ret:
            return
        frame = cv2.cvtColor(frame, cv2.COLOR_BGR2RGB)
        h, w, ch = frame.shape
        qimg = QImage(frame.data, w, h, ch * w, QImage.Format_RGB888)
        qpix = QPixmap.fromImage(qimg)
        qpix = qpix.scaled(self.label.width(), self.label.height(), Qt.KeepAspectRatio, Qt.SmoothTransformation)
        self.label.setPixmap(qpix)

    def resizeEvent(self, event):
        self.label.setGeometry(0, 0, self.width(), self.height())

    def closeEvent(self, event):
        try:
            if self.cap:
                self.cap.release()
        except Exception:
            pass
        event.accept()


