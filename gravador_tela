    def update_elapsed(self):
        if self.recording and not self.paused:
            elapsed = int(time.time() - self.start_time) if self.start_time else 0
            mm, ss = divmod(elapsed, 60)
            self.time_label.setText(f"Tempo: {mm:02d}:{ss:02d}")

    def start_recording_countdown(self):
        if self.recording:
            return
        self.showMinimized()
        self.countdown = CountdownWindow(seconds=3)
        self.countdown.finished.connect(self._begin_recording_core)
        self.countdown.start()

    def _probe_sustainable_fps(self, region, test_seconds=1.0):
        try:
            sct = mss()
            end_t = time.perf_counter() + test_seconds
            frames = 0
            while time.perf_counter() < end_t:
                _ = np.array(sct.grab(region))[:, :, :3]
                frames += 1
            measured_fps = frames / test_seconds
            for target in [60, 30, 25, 24, 20, 18, 15]:
                if measured_fps >= target * 0.9:
                    return float(target)
            return max(15.0, round(measured_fps))
        except Exception:
            return 25.0

    def _begin_recording_core(self):
        if self.temp_video.exists():
            self.temp_video.unlink()
        if self.temp_audio.exists():
            self.temp_audio.unlink()

        try:
            sct_probe = mss()
            self.monitor = sct_probe.monitors[1]
            region = self.capture_region or {
                "left": self.monitor["left"],
                "top": self.monitor["top"],
                "width": self.monitor["width"],
                "height": self.monitor["height"],
            }

            fps_text = getattr(self, "selected_fps_text", self.fps_box.currentText())
            if fps_text == "Automático":
                self.frame_rate = self._probe_sustainable_fps(region, test_seconds=1.0)
            else:
                try:
                    self.frame_rate = float(fps_text)
                except Exception:
                    self.frame_rate = 25.0

            fourcc = cv2.VideoWriter_fourcc(*"mp4v")
            self.out = cv2.VideoWriter(str(self.temp_video), fourcc, self.frame_rate,
                                       (region["width"], region["height"]))

            state = {"recording": True, "paused": False, "cursor": self.cursor_checkbox.isChecked()}
            self._state = state
            self.frame_queue = queue.Queue(maxsize=120)

            webcam_cap = None
            webcam_pos = self.webcam_position_box.currentText()
            webcam_size = (240, 180)
            if self.webcam_checkbox.isChecked():
                try:
                    cam_index = self.camera_box.currentIndex()
                    webcam_cap = cv2.VideoCapture(cam_index, cv2.CAP_DSHOW)
                    if not webcam_cap.isOpened():
                        self.info.setText(f"Não foi possível abrir a webcam no índice {cam_index}. Segue sem webcam.")
                        webcam_cap = None
                    else:
                        webcam_cap.set(cv2.CAP_PROP_FRAME_WIDTH, 640)
                        webcam_cap.set(cv2.CAP_PROP_FRAME_HEIGHT, 480)
                except Exception as e:
                    self.info.setText(f"Erro ao iniciar webcam: {e}")
                    webcam_cap = None

            start_perf = time.perf_counter()
            self.capture_thread = CaptureThread(
                region, self.frame_rate, state, self.frame_queue,
                webcam_cap=webcam_cap,
                webcam_pos=webcam_pos,
                webcam_size=webcam_size
            )
            self.writer_thread = WriterThread(self.out, self.frame_queue, state, start_time=start_perf, fps=self.frame_rate)
            self.capture_thread.start()
            self.writer_thread.start()

            try:
                self.overlay = RecordingOverlay(region)
            except Exception:
                self.overlay = None

            self.webcam_overlay = None

            self.audio_thread = None
            self.audio_data = []

            if self.audio_enabled:
                try:
                    self.audio_thread = threading.Thread(target=self.record_audio, daemon=True)
                    self.audio_thread.start()
                except Exception as e:
                    self.info.setText(f"Erro ao iniciar áudio: {e}")
                    self.audio_thread = None

            self.recording = True
            self.paused = False
            self.start_time = time.time()
            self.ui_timer.start(500)
            self.start_btn.setEnabled(False)
            self.pause_btn.setEnabled(True)
            self.stop_btn.setEnabled(True)
            self.export_btn.setEnabled(False)
            self.info.setText(f"Gravando em {self.frame_rate} FPS... (F10 para parar)")
        except Exception as e:
            self.info.setText(f"Falha ao iniciar: {e}")
            self.recording = False

    def record_audio(self):
        samplerate = self.samplerate
        channels = self.channels
        chunk_frames = samplerate // 10

        def accumulate(data):
            if data.dtype != np.float32:
                data = data.astype(np.float32)
            if data.ndim == 1:
                data = np.stack([data, data], axis=-1)
            elif data.shape[-1] == 1 and channels == 2:
                data = np.repeat(data, 2, axis=-1)
            self.audio_data.append(data)

        try:
            label = self.selected_output_label or ""
            if label.startswith("SPK:"):
                target_name = label.replace("SPK: ", "")
                speaker = None
                for spk in sc.all_speakers():
                    if spk.name == target_name:
                        speaker = spk
                        break
                if speaker is None:
                    try:
                        speaker = sc.default_speaker()
                    except Exception:
                        speaker = None

                if not speaker:
                    self.info.setText("Alto-falante não encontrado. Tentando microfone.")
                    self._record_microphone(accumulate, samplerate, channels)
                    return

                with speaker.recorder(samplerate=samplerate) as rec:
                    while getattr(self, "recording", False):
                        if getattr(self, "paused", False):
                            time.sleep(0.1)
                            continue
                        data = rec.record(numframes=chunk_frames)
                        accumulate(data)
            else:
                self._record_microphone(accumulate, samplerate, channels)

        except Exception as e:
            self.info.setText(f"Erro no áudio: {e}")

    def _record_microphone(self, accumulate, samplerate, channels):
        dev_index = self.select_microphone_device()
        if dev_index is None:
            self.info.setText("Microfone não encontrado.")
            return

        def callback(indata, frames, time_info, status):
            if getattr(self, "recording", False) and not getattr(self, "paused", False):
                accumulate(indata.copy())

        with sd.InputStream(device=dev_index, samplerate=samplerate, channels=channels,
                            dtype='float32', callback=callback):
            while getattr(self, "recording", False):
                sd.sleep(100)

    def select_microphone_device(self):
        try:
            devices = sd.query_devices()
            for idx, d in enumerate(devices):
                if d.get('max_input_channels', 0) >= 1:
                    return idx
            return None
        except Exception:
            return None

    def pause_recording(self):
        if not self.recording:
            return
        self.paused = True
        if hasattr(self, "_state"):
            self._state["paused"] = True
        self.pause_btn.setEnabled(False)
        self.resume_btn.setEnabled(True)
        self.info.setText("Pausado")
        if self.overlay:
            self.overlay.set_paused(True)

    def resume_recording(self):
        if not self.recording:
            return
        self.paused = False
        if hasattr(self, "_state"):
            self._state["paused"] = False
        self.pause_btn.setEnabled(True)
        self.resume_btn.setEnabled(False)
        self.info.setText("Gravando...")
        if self.overlay:
            self.overlay.set_paused(False)

    def stop_recording(self):
        if not self.recording:
            self.showNormal()
            return

        self.recording = False
        self.paused = False
        if hasattr(self, "_state"):
            self._state["recording"] = False

        if self.capture_thread and self.capture_thread.is_alive():
            self.capture_thread.join()
        if self.writer_thread and self.writer_thread.is_alive():
            self.writer_thread.join()

        try:
            if self.capture_thread and self.capture_thread.webcam_cap:
                self.capture_thread.webcam_cap.release()
        except Exception:
            pass

        if self.out:
            self.out.release()
            self.out = None

        if hasattr(self, "overlay") and self.overlay:
            try:
                self.overlay.close()
            except Exception:
                pass
            self.overlay = None

        if hasattr(self, "webcam_overlay") and self.webcam_overlay:
            try:
                self.webcam_overlay.close()
            except Exception:
                pass
            self.webcam_overlay = None

        if self.audio_thread:
            try:
                self.audio_thread.join()
            except RuntimeError:
                pass
            if self.audio_data:
                try:
                    data = np.concatenate(self.audio_data, axis=0)
                    sf.write(str(self.temp_audio), self._normalize_audio(data), self.samplerate)
                except Exception as e:
                    self.info.setText(f"Falha ao salvar áudio: {e}")

        self.ui_timer.stop()
        self.pause_btn.setEnabled(False)
        self.resume_btn.setEnabled(False)
        self.stop_btn.setEnabled(False)
        self.export_btn.setEnabled(True)
        self.start_btn.setEnabled(True)
        self.info.setText("GRAVAÇÃO FINALIZADA, PRONTA PARA EXPORTAR.")
        self.showNormal()

    def _normalize_audio(self, data):
        peak = np.max(np.abs(data)) if data.size else 0.0
        if peak > 1.0 and peak > 0:
            data = data / peak
        return data

    def _ffmpeg_scale_args(self, target, use_nvenc=False):
        vf = []
        if target == "720p HD":
            vf = ["-vf", "scale=1280:720"]
        elif target == "1080p Full HD":
            vf = ["-vf", "scale=1920:1080"]
        if use_nvenc:
            return vf + ["-c:v", "h264_nvenc", "-preset", "p4", "-cq", "24"]
        else:
            return vf + ["-c:v", "libx264", "-crf", "23", "-preset", "fast"]

    def export_mp4(self):
        path, _ = QFileDialog.getSaveFileName(self, "Salvar gravação como", "gravacao.mp4", "Vídeo MP4 (*.mp4)")
        if not path:
            self.info.setText("Exportação cancelada.")
            return

        try:
            dst = Path(path)
            if not self.temp_video.exists():
                self.info.setText("Erro: vídeo temporário não encontrado.")
                return

            resolution = self.resolution_box.currentText()
            use_nvenc = False
            v_args = self._ffmpeg_scale_args(resolution, use_nvenc=use_nvenc)

            try:
                ffmpeg = get_ffmpeg()
            except FileNotFoundError as e:
                shutil.copy2(str(self.temp_video), str(dst))
                self.info.setText(f"{e}\nExportado original sem redimensionar/áudio.")
                self.export_btn.setEnabled(False)
                return

            fps_out = str(self.frame_rate)

            if self.audio_enabled and self.temp_audio.exists():
                cmd = [
                    ffmpeg, "-y",
                    "-i", str(self.temp_video),
                    "-i", str(self.temp_audio),
                    "-r", fps_out,
                    *v_args,
                    "-c:a", "aac",
                    "-shortest",
                    str(dst)
                ]
            else:
                cmd = [
                    ffmpeg, "-y",
                    "-i", str(self.temp_video),
                    "-r", fps_out,
                    *v_args,
                    str(dst)
                ]

            self.progress_bar.setValue(0)
            self.progress_bar.show()
            self.progress_label.setText("Convertendo...")
            self.progress_label.show()
            QApplication.processEvents()

            creationflags = 0
            if sys.platform == "win32":
                creationflags = subprocess.CREATE_NO_WINDOW

            process = subprocess.Popen(
                cmd,
                stdout=subprocess.DEVNULL,
                stderr=subprocess.PIPE,
                text=True,
                encoding='utf-8',
                errors='ignore',
                creationflags=creationflags
            )

            total_duration = None
            last_progress = 0

            for line in iter(process.stderr.readline, ''):
                if "Duration:" in line and total_duration is None:
                    try:
                        dur_str = line.split("Duration:")[1].split(",")[0].strip()
                        h, m, s = dur_str.split(":")
                        total_duration = int(h) * 3600 + int(m) * 60 + float(s)
                    except Exception:
                        total_duration = None

                if "time=" in line and total_duration:
                    try:
                        time_str = line.split("time=")[1].split(" ")[0]
                        h, m, s = time_str.split(":")
                        current_time = int(h) * 3600 + int(m) * 60 + float(s)
                        progress = max(0, min(100, int((current_time / total_duration) * 100)))
                        if progress != last_progress:
                            self.progress_bar.setValue(progress)
                            remaining = max(0, total_duration - current_time)
                            mm, ss = divmod(int(remaining), 60)
                            self.progress_label.setText(f"Convertendo... {progress}% - Restante: {mm:02d}:{ss:02d}")
                            last_progress = progress
                            QApplication.processEvents()
                    except Exception:
                        pass

            process.wait()

            if process.returncode == 0 and dst.exists():
                self.progress_bar.setValue(100)
                self.progress_label.setText("Concluído com sucesso!")
                self.info.setText(f"Exportado: {dst}")
            else:
                shutil.copy2(str(self.temp_video), str(dst))
                self.info.setText("Falha no ffmpeg. Exportado original sem redimensionar.")

            self.export_btn.setEnabled(False)
            QTimer.singleShot(2000, self.progress_bar.hide)
            QTimer.singleShot(2000, self.progress_label.hide)

        except Exception as e:
            self.info.setText(f"Falha na exportação: {str(e)}")
            self.progress_bar.hide()
            self.progress_label.hide()

    def closeEvent(self, event):
        try:
            keyboard.clear_all_hotkeys()
        except Exception:
            pass
        super().closeEvent(event)


